{
    "resblock": "1",
    "num_gpus": 0,
    "batch_size": 128,
    "learning_rate": 0.0001,
    "warmup_step": 5000,
    "adam_b1": 0.8,
    "adam_b2": 0.99,
    "lr_decay": 0.9999996,
    "seed": 1234,

    "upsample_rates": [4,4,2,2,2,2],
    "upsample_kernel_sizes": [8,8,4,4,4,4],
    "upsample_initial_channel": 1536,
    "resblock_kernel_sizes": [3,7,11],
    "resblock_dilation_sizes": [[1,3,5], [1,3,5], [1,3,5]],

    "activation": "snakebeta",
    "snake_logscale": true,

    "resolutions": [[1024, 120, 600], [2048, 240, 1200], [512, 50, 240]],
    "mpd_reshapes": [2, 3, 5, 7, 11],
    "use_spectral_norm": false,
    "mpd_channel_mult": 1,

    "use_dac_mcbd_instead_of_mrd": true,
    "mcbd_apply_large_kernel_to_freq": false,
    "mcbd_fft_sizes": [2048, 1024, 512],
    "mcbd_hop_factor": 0.25,
    "mcbd_bands": [[0.0, 0.1], [0.1, 0.25], [0.25, 0.5], [0.5, 0.75], [0.75, 1.0]],

    "use_dac_melloss_instead_of_l1": true,
    "lambda_melloss": 15,

    "clip_grad_norm": 1000,

    "segment_size": 16384,
    "num_mels": 80,
    "num_linears": 513,
    "n_fft": 1024,
    "hop_size": 256,
    "win_size": 1024,

    "sampling_rate": 22050,

    "fmin": 0,
    "fmax": 8000,
    "fmax_for_loss": null,

    "normalize_volume": true,

    "num_workers": 4,

    "dist_config": {
        "dist_backend": "nccl",
        "dist_url": "tcp://localhost:54321",
        "world_size": 1
    }
}
