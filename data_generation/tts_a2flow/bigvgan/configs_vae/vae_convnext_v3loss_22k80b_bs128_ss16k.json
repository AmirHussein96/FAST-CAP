{
    "model_type": "vae",

    "num_gpus": 0,
    "batch_size": 128,
    "learning_rate": 0.0001,
    "warmup_step": 5000,
    "adam_b1": 0.8,
    "adam_b2": 0.99,
    "clip_grad_norm": 1000,
    "lr_decay": 0.9999996,
    "seed": 1234,

    "sampling_rate": 22050,
    "fmin": 0,
    "fmax": 8000,
    "fmax_for_loss": null,
    "normalize_volume": true,

    "segment_size": 16384,
    "num_mels": 80,
    "num_linears": 513,
    "n_fft": 1024,
    "hop_size": 256,
    "win_size": 1024,

    "enc_type": "convnext",
    "enc_dim": 512,
    "enc_intermediate_dim": 1536,
    "enc_num_layers": 8,

    "vocoder_input_dim": 128,
    "resblock": "1",
    "upsample_rates": [4,4,2,2,2,2],
    "upsample_kernel_sizes": [8,8,4,4,4,4],
    "upsample_initial_channel": 1536,
    "resblock_kernel_sizes": [3,7,11],
    "resblock_dilation_sizes": [[1,3,5], [1,3,5], [1,3,5]],
    "activation": "snakebeta",
    "snake_logscale": true,

    "mpd_reshapes": [2, 3, 5, 7, 11],
    "use_spectral_norm": false,
    "mpd_channel_mult": 1,
    "use_dac_mrd_instead_of_original": true,
    "use_dac_melloss_instead_of_l1": true,
    "lambda_melloss": 15,
    "lambda_klloss": 0.000001,

    "num_workers": 4,
    "dist_config": {
        "dist_backend": "nccl",
        "dist_url": "tcp://localhost:54321",
        "world_size": 1
    }
}
